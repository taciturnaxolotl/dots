#!/usr/bin/env sh

# yabai configuration — replicates ~/.aerospace.toml

# Global settings
yabai -m config mouse_follows_focus          on
yabai -m config focus_follows_mouse          autofocus
yabai -m config window_placement             second_child
yabai -m config split_ratio                  0.50
yabai -m config auto_balance                 off

# Mouse modifier (alt + drag = move, alt + right drag = resize)
yabai -m config mouse_modifier               alt
yabai -m config mouse_action1                move
yabai -m config mouse_action2                resize

# Layout defaults (global)
yabai -m config layout                       bsp
yabai -m config split_type                   auto

# Apply to all existing spaces
for SPACE in $(yabai -m query --spaces | jq -r '.[].index'); do
  yabai -m config --space "$SPACE" layout             bsp
  yabai -m config --space "$SPACE" split_type         auto
  yabai -m config --space "$SPACE" top_padding        8
  yabai -m config --space "$SPACE" bottom_padding     8
  yabai -m config --space "$SPACE" left_padding       8
  yabai -m config --space "$SPACE" right_padding      8
  yabai -m config --space "$SPACE" window_gap         6
done

# Rules: float these apps (must come before space-assignment rules)
yabai -m rule --add app="^Dia$" title="^Bitwarden$" float=on
yabai -m rule --add app="^UTM$"             manage=off
yabai -m rule --add app="^VMware Fusion$"   manage=off
yabai -m rule --add app="^FaceTime$"        manage=off
yabai -m rule --add app="^Screen Sharing$"  manage=off
yabai -m rule --add app="^Antinote$"        manage=off
yabai -m rule --add app="^hw05$"            manage=off
# Rules: assign apps to specific spaces
yabai -m rule --add app="^Dia$" title="^Personal:"   space=1
yabai -m rule --add app="^Dia$" title="^Charm"        space=2
yabai -m rule --add app="^Dia$" title="^Cedarville"   space=2
yabai -m rule --add app="^Slack$"                     space=8
yabai -m rule --add app="^Vesktop$"                   space=7
yabai -m rule --add app="^Notion$"                    space=9

# Rules: unmanaged apps
yabai -m rule --add app="^Finder$" subrole="AXDialog" manage=off
yabai -m rule --add app="^Finder$" title="^Copy$" manage=off
yabai -m rule --add app="^Finder$" title="^Trash$" manage=off

echo "yabai config loaded"
